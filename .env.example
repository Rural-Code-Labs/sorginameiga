# Copy to `.env` for local development (do not commit real secrets).

# Database (defaults match the `db` service in docker-compose.yml)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=vapor_username
DATABASE_PASSWORD=vapor_password
DATABASE_NAME=vapor_database

# Initial admin password (hashed with bcrypt at migration time).
# Set a strong value in production (e.g. a Cloud Run secret).
ADMIN_PASSWORD=changeme
